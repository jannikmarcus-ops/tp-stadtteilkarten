{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://teigelerundpartner.de"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://teigelerundpartner.de https://*.teigelerundpartner.de"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://teigelerundpartner.de"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
